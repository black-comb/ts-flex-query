{
  "name": "ts-flex-query",
  "version": "1.0.0",
  "description": "Flexible and type-safe data queries",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "karma.conf.js"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.lib.json",
    "lint": "eslint ./src --ext .js,.jsx,.ts,.tsx",
    "lint-fix": "eslint ./src --ext .js,.jsx,.ts,.tsx --fix",
    "test": "tsc -p ./tsconfig.test.json && karma start karma.conf.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/black-comb/ts-flex-query.git"
  },
  "keywords": [
    "data",
    "query",
    "odata"
  ],
  "author": "Marko Martin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/black-comb/ts-flex-query/issues"
  },
  "homepage": "https://github.com/black-comb/ts-flex-query#readme",
  "devDependencies": {
    "@types/jasmine": "^3.10.3",
    "@types/lodash": "^4.14.178",
    "@typescript-eslint/eslint-plugin": "^5.10.0",
    "@typescript-eslint/parser": "^5.10.0",
    "eslint": "^8.7.0",
    "jasmine": "^4.0.2",
    "karma": "^6.3.16",
    "karma-chrome-launcher": "^3.1.0",
    "karma-jasmine": "^4.0.1",
    "karma-typescript": "^5.5.3",
    "typescript": "^4.5.5"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "rxjs": "^7.5.2"
  }
}
